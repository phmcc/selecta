Package: selecta
Type: Package
Title: EQUATOR-Style Enrollment Diagrams for Clinical Studies
Version: 0.2.0
Authors@R: c(
    person(
        given = c("Paul", "Hsin-ti"), 
        family = "McClelland", 
        role = c("aut", "cre", "cph"), 
        email = "PaulHMcClelland@protonmail.com",
        comment = c(ORCID = "0000-0002-3119-6531")
